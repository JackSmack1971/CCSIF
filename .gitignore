# Claude local overrides
CLAUDE.local.md
.claude/settings.local.json
.claude/worktrees/*
!.claude/worktrees/.gitkeep

# Generated telemetry (self-improve trace corpus)
.claude/traces/*.jsonl

# Local Claude Code memory runtime state. Keep source files in .claude/memory/
# tracked; ignore only generated state and heavyweight local indexes.
.claude/memory/state/
.claude/memory/.venv/
.claude/memory/*.db
.claude/memory/*.sqlite
.claude/memory/*.sqlite3
.claude/memory/*.jsonl
.claude/projects/

# Secrets
.env
.env.*
*.pem
*.key
*credentials*
*service-account*

# Phase 0 control-plane runtime state: generated locally per session.
# Tracked ledgers/reports/roadmap evidence under .claude/state/ (ledger.md,
# baseline.md, completion-matrix.md, execution-manifest.json, roadmap/**,
# research/**, handoffs/**, and every .gitkeep) remain committed.
.claude/state/phase0.sqlite3
.claude/state/phase0.sqlite3-wal
.claude/state/phase0.sqlite3-shm
.claude/state/phase0.sqlite3-journal
.claude/state/raw
.claude/state/raw/
.claude/state/logs
.claude/state/logs/
.claude/state/checkpoints
.claude/state/checkpoints/
.claude/state/archive
.claude/state/archive/
.claude/state/compactions/*
!.claude/state/compactions/.gitkeep
.claude/state/agents/*
!.claude/state/agents/.gitkeep
.claude/state/workflows/*
!.claude/state/workflows/.gitkeep

# Common build artifacts
node_modules/
dist/
build/
coverage/
__pycache__/
.pytest_cache/
.cache/
.DS_Store
