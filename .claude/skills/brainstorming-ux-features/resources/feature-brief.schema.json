{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/ux-feature-contract-1.0.json",
  "title": "UX Feature Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_type",
    "feature_id",
    "slug",
    "title",
    "status",
    "generated_from",
    "decision",
    "problem",
    "outcomes",
    "scope",
    "ux_design",
    "implementation",
    "acceptance_criteria",
    "test_plan",
    "rollout",
    "risks",
    "open_questions",
    "agent_handoff"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "document_type": {"type": "string", "enum": ["ux_feature_contract"]},
    "feature_id": {"type": "string", "pattern": "^uxf-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 3},
    "status": {"type": "string", "enum": ["proposed", "approved", "ready_for_implementation"]},
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "requested_focus", "evidence"],
      "properties": {
        "project": {"type": "string", "minLength": 1},
        "requested_focus": {"type": "string", "minLength": 1},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence"}
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_candidate_id", "selection_rationale", "candidates"],
      "properties": {
        "selected_candidate_id": {"type": "string", "pattern": "^cand-[0-9]{2}$"},
        "selection_rationale": {"type": "string", "minLength": 20},
        "candidates": {
          "type": "array",
          "minItems": 5,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/candidate"}
        }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "affected_users", "jobs_to_be_done", "current_friction", "evidence_refs"],
      "properties": {
        "statement": {"type": "string", "minLength": 30},
        "affected_users": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
        "jobs_to_be_done": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
        "current_friction": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^ev-[0-9]{2}$"}}
      }
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_value", "product_value", "metrics"],
      "properties": {
        "user_value": {"type": "string", "minLength": 20},
        "product_value": {"type": "string", "minLength": 20},
        "metrics": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/metric"}}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mvp", "in_scope", "non_goals", "assumptions", "constraints"],
      "properties": {
        "mvp": {"type": "string", "minLength": 30},
        "in_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "assumptions": {"type": "array", "items": {"type": "string", "minLength": 5}},
        "constraints": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    },
    "ux_design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_points", "primary_flow", "alternate_flows", "states", "accessibility", "content_guidance", "user_controls"],
      "properties": {
        "entry_points": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
        "primary_flow": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/flow_step"}},
        "alternate_flows": {"type": "array", "items": {"$ref": "#/$defs/alternate_flow"}},
        "states": {"type": "array", "minItems": 12, "items": {"$ref": "#/$defs/ux_state"}},
        "accessibility": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/check_item"}},
        "content_guidance": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "user_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["architecture_fit", "work_items", "data_changes", "api_changes", "analytics_events", "security_privacy"],
      "properties": {
        "architecture_fit": {"type": "string", "minLength": 30},
        "work_items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/work_item"}},
        "data_changes": {"type": "array", "items": {"type": "string", "minLength": 5}},
        "api_changes": {"type": "array", "items": {"type": "string", "minLength": 5}},
        "analytics_events": {"type": "array", "items": {"$ref": "#/$defs/analytics_event"}},
        "security_privacy": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/acceptance_criterion"}
    },
    "test_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "integration", "end_to_end", "accessibility", "manual"],
      "properties": {
        "unit": {"type": "array", "items": {"type": "string", "minLength": 5}},
        "integration": {"type": "array", "items": {"type": "string", "minLength": 5}},
        "end_to_end": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "accessibility": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "manual": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_flag", "phases", "rollback_triggers", "rollback_plan", "observability"],
      "properties": {
        "feature_flag": {"type": "string", "minLength": 1},
        "phases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "rollback_triggers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "rollback_plan": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "observability": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    },
    "risks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/risk"}},
    "open_questions": {"type": "array", "items": {"$ref": "#/$defs/open_question"}},
    "agent_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_order", "parallel_groups", "stop_conditions", "completion_evidence"],
      "properties": {
        "execution_order": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^work-[0-9]{2}$"}},
        "parallel_groups": {"type": "array", "items": {"type": "array", "minItems": 2, "items": {"type": "string", "pattern": "^work-[0-9]{2}$"}}},
        "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "completion_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "observation", "relevance"],
      "properties": {
        "id": {"type": "string", "pattern": "^ev-[0-9]{2}$"},
        "type": {"type": "string", "enum": ["repository", "user_statement", "analytics", "support", "assumption"]},
        "source": {"type": "string", "minLength": 1},
        "observation": {"type": "string", "minLength": 10},
        "relevance": {"type": "string", "minLength": 10}
      }
    },
    "score_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_pain", "frequency_or_reach", "ux_leverage", "strategic_fit", "evidence_confidence", "implementation_feasibility", "differentiation"],
      "properties": {
        "user_pain": {"type": "number", "minimum": 0, "maximum": 5},
        "frequency_or_reach": {"type": "number", "minimum": 0, "maximum": 5},
        "ux_leverage": {"type": "number", "minimum": 0, "maximum": 5},
        "strategic_fit": {"type": "number", "minimum": 0, "maximum": 5},
        "evidence_confidence": {"type": "number", "minimum": 0, "maximum": 5},
        "implementation_feasibility": {"type": "number", "minimum": 0, "maximum": 5},
        "differentiation": {"type": "number", "minimum": 0, "maximum": 5}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "problem", "target_user", "evidence_refs", "measurable_outcome", "vertical_slice", "duplication_check", "minimum_gates", "scores", "risk_penalty", "total_score", "disposition"],
      "properties": {
        "id": {"type": "string", "pattern": "^cand-[0-9]{2}$"},
        "title": {"type": "string", "minLength": 3},
        "problem": {"type": "string", "minLength": 20},
        "target_user": {"type": "string", "minLength": 3},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^ev-[0-9]{2}$"}},
        "measurable_outcome": {"type": "string", "minLength": 10},
        "vertical_slice": {"type": "string", "minLength": 20},
        "duplication_check": {"type": "string", "minLength": 10},
        "minimum_gates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["concrete_problem", "distinct", "measurable", "end_to_end_mvp", "constraint_compatible"],
          "properties": {
            "concrete_problem": {"type": "boolean"},
            "distinct": {"type": "boolean"},
            "measurable": {"type": "boolean"},
            "end_to_end_mvp": {"type": "boolean"},
            "constraint_compatible": {"type": "boolean"}
          }
        },
        "scores": {"$ref": "#/$defs/score_set"},
        "risk_penalty": {"type": "number", "minimum": 0, "maximum": 15},
        "total_score": {"type": "number", "minimum": 0, "maximum": 100},
        "disposition": {"type": "string", "enum": ["selected", "rejected", "deferred"]}
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "definition", "baseline", "target", "instrumentation", "review_window", "guardrail"],
      "properties": {
        "id": {"type": "string", "pattern": "^metric-[0-9]{2}$"},
        "name": {"type": "string", "minLength": 3},
        "kind": {"type": "string", "enum": ["primary", "diagnostic", "guardrail"]},
        "definition": {"type": "string", "minLength": 15},
        "baseline": {"type": "string", "minLength": 1},
        "target": {"type": "string", "minLength": 3},
        "instrumentation": {"type": "string", "minLength": 5},
        "review_window": {"type": "string", "minLength": 3},
        "guardrail": {"type": "string", "minLength": 5}
      }
    },
    "flow_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "actor", "action", "system_response", "success_condition"],
      "properties": {
        "id": {"type": "string", "pattern": "^flow-[0-9]{2}$"},
        "actor": {"type": "string", "minLength": 2},
        "action": {"type": "string", "minLength": 5},
        "system_response": {"type": "string", "minLength": 5},
        "success_condition": {"type": "string", "minLength": 5}
      }
    },
    "alternate_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "trigger", "steps", "resolution"],
      "properties": {
        "name": {"type": "string", "minLength": 3},
        "trigger": {"type": "string", "minLength": 5},
        "steps": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
        "resolution": {"type": "string", "minLength": 5}
      }
    },
    "ux_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "applicable", "trigger", "experience", "recovery", "not_applicable_reason"],
      "properties": {
        "id": {"type": "string", "pattern": "^state-[0-9]{2}$"},
        "type": {"type": "string", "enum": ["idle", "loading", "success", "empty", "error", "permission", "authentication", "offline", "partial", "interrupted", "cancelled", "stale"]},
        "applicable": {"type": "boolean"},
        "trigger": {"type": "string"},
        "experience": {"type": "string"},
        "recovery": {"type": "string"},
        "not_applicable_reason": {"type": "string"}
      }
    },
    "check_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["area", "requirement", "verification"],
      "properties": {
        "area": {"type": "string", "minLength": 3},
        "requirement": {"type": "string", "minLength": 10},
        "verification": {"type": "string", "minLength": 10}
      }
    },
    "path_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "rationale"],
      "properties": {
        "path": {"type": "string", "pattern": "^(?!/)(?!.*\\\\).+$"},
        "operation": {"type": "string", "enum": ["create", "modify", "delete"]},
        "rationale": {"type": "string", "minLength": 10}
      }
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "objective", "paths", "instructions", "dependencies", "verification", "done_when"],
      "properties": {
        "id": {"type": "string", "pattern": "^work-[0-9]{2}$"},
        "title": {"type": "string", "minLength": 3},
        "objective": {"type": "string", "minLength": 15},
        "paths": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/path_change"}},
        "instructions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
        "dependencies": {"type": "array", "items": {"type": "string", "pattern": "^work-[0-9]{2}$"}},
        "verification": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
        "done_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}}
      }
    },
    "analytics_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "trigger", "properties", "purpose"],
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "trigger": {"type": "string", "minLength": 5},
        "properties": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "purpose": {"type": "string", "minLength": 10}
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "given", "when", "then", "verification"],
      "properties": {
        "id": {"type": "string", "pattern": "^ac-[0-9]{2}$"},
        "given": {"type": "string", "minLength": 5},
        "when": {"type": "string", "minLength": 5},
        "then": {"type": "string", "minLength": 10},
        "verification": {"type": "string", "minLength": 5}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "risk", "likelihood", "impact", "mitigation", "owner"],
      "properties": {
        "id": {"type": "string", "pattern": "^risk-[0-9]{2}$"},
        "risk": {"type": "string", "minLength": 10},
        "likelihood": {"type": "string", "enum": ["low", "medium", "high"]},
        "impact": {"type": "string", "enum": ["low", "medium", "high"]},
        "mitigation": {"type": "string", "minLength": 10},
        "owner": {"type": "string", "minLength": 2}
      }
    },
    "open_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "blocking", "owner", "default_if_unanswered"],
      "properties": {
        "id": {"type": "string", "pattern": "^question-[0-9]{2}$"},
        "question": {"type": "string", "minLength": 10},
        "blocking": {"type": "boolean"},
        "owner": {"type": "string", "minLength": 2},
        "default_if_unanswered": {"type": "string", "minLength": 5}
      }
    }
  }
}
