        ".claude/scripts/rules_fidelity_check.py"
      ]
    },
    {
      "id": "memory-tests",
      "label": "memory tests",
      "command": [
        "python3",
        "-m",
        "unittest",
        "discover",
        "-s",
        ".claude/memory/tests",
        "-v"
      ]
    },
    {
      "id": "issue-to-pr-tests",
      "label": "issue-to-pr tests",
      "command": [
        "python3",
        "-m",
        "unittest",
