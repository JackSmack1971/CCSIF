{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "version": 1,
  "description": "Shared project Claude Code settings. Commit only team-safe values.",
  "enabledMcpjsonServers": ["graphiti-memory"],
  "claudeMdExcludes": [
    ".claude/worktrees/**/CLAUDE.md",
    ".claude/worktrees/**/CLAUDE.local.md"
  ],
  "disableSkillShellExecution": true,
  "plansDirectory": "./.claude/plans",
  "permissions": {
    "mode": "ask",
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log --oneline -20)",
      "Bash(python3 .claude/scripts/control_plane_check.py)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(terraform destroy:*)",
      "Bash(kubectl delete:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session-start.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pre-tool-use.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/post-tool-use.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pre-compact.sh" }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/post-compact.sh" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/subagent-start.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/subagent-stop.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/hindsight-recall.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/stop.sh" }
        ]
      }
    ]
  }
}
